# Digital Twin Truck Configurator - Configuration Template
# Copy this file to config.env and fill in your values

# ============================================
# REQUIRED: Account Information
# ============================================

# Your Snowflake account locator (e.g., MYORG-MYACCOUNT)
SNOWFLAKE_ACCOUNT=

# Full hostname (usually <account>.snowflakecomputing.com)
SNOWFLAKE_HOST=

# Username for the service
SNOWFLAKE_USER=

# Warehouse for running queries
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# ============================================
# REQUIRED: Database Objects
# ============================================

# Database name (will be created if doesn't exist)
DATABASE_NAME=BOM

# Schema name (will be created if doesn't exist)
SCHEMA_NAME=TRUCK_CONFIG

# ============================================
# REQUIRED: SPCS Resources
# ============================================

# Compute pool name
COMPUTE_POOL_NAME=TRUCK_CONFIG_POOL

# Image repository name
IMAGE_REPO_NAME=TRUCK_CONFIG_REPO

# Service name
SERVICE_NAME=TRUCK_CONFIGURATOR_SVC

# External access integration name
EXTERNAL_ACCESS_INTEGRATION=TRUCK_CONFIG_EXTERNAL_ACCESS

# ============================================
# REQUIRED: Authentication Secrets
# ============================================

# Path to PAT file (one line, the token only)
# Create at: Snowsight → Profile → Security → Personal Access Tokens
PAT_FILE_PATH=./secrets/pat.txt

# Path to private key file (PEM format)
# Generate with: openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt -out key.p8
PRIVATE_KEY_FILE_PATH=./secrets/private_key.pem

# ============================================
# OPTIONAL: Semantic View
# ============================================

# Name of the semantic view for Cortex Analyst
SEMANTIC_VIEW_NAME=TRUCK_CONFIG_ANALYST_V2

# ============================================
# OPTIONAL: Docker Image
# ============================================

# Image tag (increment for updates)
IMAGE_TAG=v1
